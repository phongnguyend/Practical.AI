    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.DataIngestion" Version="10.5.0-preview.1.26213.4" />
    <PackageReference Include="Microsoft.Extensions.DataIngestion.MarkItDown" Version="10.5.0-preview.1.26213.4" />
